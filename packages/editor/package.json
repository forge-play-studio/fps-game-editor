{
  "name": "@fps-games/editor",
  "version": "0.1.0-alpha.0",
  "type": "module",
  "description": "Aggregate public entrypoint for fps-game-editor.",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fps-games/editor-babylon": "0.1.0-alpha.0",
    "@fps-games/editor-browser": "0.1.0-alpha.0",
    "@fps-games/editor-core": "0.1.0-alpha.0",
    "@fps-games/editor-forge-play": "0.1.0-alpha.0",
    "@fps-games/editor-protocol": "0.1.0-alpha.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
