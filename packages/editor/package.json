{
  "name": "@fps-games/editor",
  "version": "0.1.2-beta.1",
  "type": "module",
  "description": "Aggregate public entrypoint for fps-game-editor.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/forge-play-studio/fps-game-editor.git",
    "directory": "packages/editor"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepack": "node ../../scripts/prepare-single-package.mjs"
  },
  "dependencies": {
    "@fps-games/babylon-renderer": "0.1.2-beta.1",
    "@fps-games/editor-babylon": "0.1.2-beta.1",
    "@fps-games/editor-browser": "0.1.2-beta.1",
    "@fps-games/editor-core": "0.1.2-beta.1",
    "@fps-games/editor-forge-play": "0.1.2-beta.1",
    "@fps-games/editor-protocol": "0.1.2-beta.1"
  },
  "bundleDependencies": [
    "@fps-games/babylon-renderer",
    "@fps-games/editor-babylon",
    "@fps-games/editor-browser",
    "@fps-games/editor-core",
    "@fps-games/editor-forge-play",
    "@fps-games/editor-protocol"
  ],
  "publishConfig": {
    "access": "public"
  }
}
