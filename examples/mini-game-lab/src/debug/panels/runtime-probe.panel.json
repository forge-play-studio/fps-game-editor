{
  "id": "runtime-probe",
  "title": "运行时 Probe",
  "configFile": "panel-framework.json",
  "category": "Framework",
  "controller": "runtimeProbe",
  "persistence": "config",
  "params": [
    {
      "key": "enabled",
      "label": "启用",
      "type": "boolean",
      "configPaths": ["runtimeProbe.enabled"],
      "runtimePath": "enabled",
      "default": false,
      "description": "验证 Debug Panel Framework 的 boolean live patch 和配置保存。"
    },
    {
      "key": "intensity",
      "label": "强度",
      "type": "number",
      "configPaths": ["runtimeProbe.intensity"],
      "runtimePath": "intensity",
      "default": 1,
      "range": [0, 5],
      "step": 0.1,
      "description": "验证 number 控件和 runtimePath patch。"
    },
    {
      "key": "tint",
      "label": "颜色",
      "type": "color",
      "configPaths": ["runtimeProbe.tint"],
      "runtimePath": "tint",
      "default": [0.35, 0.72, 1],
      "description": "验证 color 控件、数组保存与 runtime patch。"
    },
    {
      "key": "mode",
      "label": "模式",
      "type": "select",
      "configPaths": ["runtimeProbe.mode"],
      "runtimePath": "mode",
      "default": "soft",
      "options": [
        { "label": "Soft", "value": "soft" },
        { "label": "Sharp", "value": "sharp" },
        { "label": "Pulse", "value": "pulse" }
      ],
      "description": "验证 select 控件。"
    },
    {
      "key": "note",
      "label": "备注",
      "type": "string",
      "configPaths": ["runtimeProbe.note"],
      "runtimePath": "note",
      "default": "lumber_order debug panel probe",
      "description": "验证 string 控件。"
    },
    {
      "key": "action.flash",
      "label": "触发动作",
      "type": "action",
      "configPaths": [],
      "default": 0,
      "action": "flash",
      "actionArgs": {
        "intensity": "$values.intensity",
        "mode": "$values.mode"
      },
      "description": "验证显式 action 只在点击时触发。"
    }
  ]
}
