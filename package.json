{
  "name": "fps-game-editor",
  "version": "0.1.1-beta.5",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "build:editor-lab": "vite build --config examples/editor-lab/vite.config.ts",
    "build:editor-world": "vite build --config examples/babylon-editor-world/vite.config.ts",
    "clean": "tsc -b --clean",
    "dev:editor-lab": "vite --config examples/editor-lab/vite.config.ts --host 0.0.0.0",
    "dev:mini-game-lab": "npm --prefix examples/mini-game-lab run dev:editor-local --",
    "dev:editor-world": "vite --config examples/babylon-editor-world/vite.config.ts --host 0.0.0.0",
    "typecheck": "tsc -b --emitDeclarationOnly && tsc -p examples/editor-lab/tsconfig.json --noEmit && tsc -p examples/babylon-editor-world/tsconfig.json --noEmit",
    "typecheck:mini-game-lab": "npm --prefix examples/mini-game-lab run typecheck",
    "test:unit": "vitest run",
    "test:browser": "playwright test",
    "test:pack": "node scripts/pack-consumer-smoke.mjs",
    "test": "npm run test:unit && npm run test:browser && npm run test:pack",
    "check:boundaries": "node scripts/check-package-boundaries.mjs",
    "docs:export-user-guide": "node scripts/docs/export-editor-user-guide-md.mjs",
    "docs:check-user-guide": "node scripts/docs/check-editor-user-docs.mjs",
    "check": "npm run check:boundaries && npm run typecheck && npm run test:unit",
    "pack:dry-run": "node scripts/pack-dry-run.mjs",
    "release:version": "node scripts/release-version.mjs set",
    "release:check": "node scripts/release-version.mjs check",
    "release:check:beta": "node scripts/release-version.mjs check --channel beta",
    "release:check:stable": "node scripts/release-version.mjs check --channel stable",
    "release:verify": "npm run release:check && npm run check && npm run build && npm run build:editor-lab && npm run test:browser && npm run test:pack && npm run pack:dry-run"
  },
  "devDependencies": {
    "@babylonjs/core": "^8.0.0",
    "@playwright/test": "^1.60.0",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vitest": "^4.1.7"
  }
}
